# --- Основные настройки проекта ---
PROJECT_NAME           = "ADAS Integrated System"
PROJECT_NUMBER         = 1.0
OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRECTORY    = YES
OUTPUT_LANGUAGE        = Russian
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES

# --- Настройки входных файлов ---
# Doxygen будет искать код в папках src и include
INPUT                  = src README.md
RECURSIVE              = YES
FILE_PATTERNS          = *.cpp *.h *.md

# --- Настройки извлечения данных ---
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES

# --- Настройки отображения ---
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# --- Форматы вывода ---
GENERATE_HTML          = YES
HTML_OUTPUT            = html
# Отключаем Latex, чтобы быстрее собиралось и не требовало лишнего софта
GENERATE_LATEX         = NO

# --- Красивое оформление (Markdown) ---
USE_MDFILE_AS_MAINPAGE = README.md
MARKDOWN_SUPPORT       = YES